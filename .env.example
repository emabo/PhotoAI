# -----------------------------
# PhotoAI environment template
# Copy this file to .env and edit values for your machine.
# -----------------------------

# Core paths
PHOTOAI_PHOTOS_DIR=/absolute/path/to/photos
PHOTOAI_SQLITE_DIR=/absolute/path/to/db/sqlite
PHOTOAI_CHROMA_DIR=/absolute/path/to/db/chroma
PHOTOAI_THUMB_DIR=/absolute/path/to/cache/thumbs

# Main model/index config
PHOTOAI_COLLECTION=images_openclip_vitl14_336
PHOTOAI_CAPTIONS_COLLECTION=captions_openclip_vitl14_336
PHOTOAI_DEVICE=cuda
PHOTOAI_DTYPE=bf16

# Caption pipeline
PHOTOAI_CAPTION_MODEL=Salesforce/blip2-flan-t5-xxl
PHOTOAI_TRANSLATE_MODEL=facebook/nllb-200-distilled-600M
PHOTOAI_CAPTION_STEP=caption
PHOTOAI_CAPTION_PASS_LIMIT=16

# Server/search tuning
PHOTOAI_THUMB_SIZE=256
PHOTOAI_DEFAULT_K=60
PHOTOAI_MAX_K=200
PHOTOAI_MAX_CANDIDATES=1000
PHOTOAI_RESTRICT_TO_PHOTOS_DIR=1

# Verify helper
PHOTOAI_TEST_QUERY_IT=una foto di un gatto
